{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "semiColons": false
  },
  "imports": {
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "@hey-api/openapi-ts": "npm:@hey-api/openapi-ts@^0.97.0",
    "@hey-api/vite-plugin": "npm:@hey-api/vite-plugin@^0.3.1",
    "@kysely/kysely": "jsr:@kysely/kysely@^0.28.16",
    "@skyware/jetstream": "npm:@skyware/jetstream@^0.2.5",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "mysql2": "npm:mysql2@^3.22.3",
    "preact": "npm:preact@^10.29.1",
    "vite": "npm:vite@^7.3.2"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "tasks": {
    "dev": "deno run -A vite"
  },
  "unstable": [
    "sloppy-imports" // Required for generated traQ client code
  ]
}
